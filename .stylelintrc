{
    "extends": [
        "stylelint-config-recommended-scss"
    ],
    "plugins": [
        "stylelint-order",
        "stylelint-declaration-block-no-ignored-properties"
    ],
    "rules": {
        "selector-class-pattern": "^.[a-z]([a-z0-9-]+)?(__([a-z0-9]+-?)+)?(--([a-z0-9]+-?)+){0,2}$",
        "max-nesting-depth": 3,
        "selector-max-id": 0,
        "selector-max-compound-selectors": 3,
        "color-named": "never"
    }
}